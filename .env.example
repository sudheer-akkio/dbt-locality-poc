# =============================================================================
# dbt Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your target environment.
# Usage: dbt run --target staging   (or --target prod)
#
# The profile "locality" in ~/.dbt/profiles.yml defines two targets:
#   staging  → akkio.locality_poc  (token auth)
#   prod     → locality_dev.akkio  (OAuth service principal)
# =============================================================================

# --- Connection (required for staging, optional for prod with defaults) ---
DBT_DATABRICKS_HOST=              # e.g. adb-1234567890.cloud.databricks.com
DBT_DATABRICKS_HTTP_PATH=         # e.g. /sql/1.0/warehouses/abc123 (optional, has per-target defaults)

# --- Auth: Token (staging) ---
DBT_DATABRICKS_TOKEN=             # Databricks personal access token

# --- Auth: OAuth (prod) ---
DBT_DATABRICKS_CLIENT_ID=         # Service principal client ID
DBT_DATABRICKS_CLIENT_SECRET=     # Service principal client secret

# --- Source catalog (required — used in schema.yml for source tables) ---
# Staging: locality-poc-share (Delta Share)
# Prod: set to whatever catalog contains the source tables locally
DBT_SOURCE_CATALOG=locality-poc-share
